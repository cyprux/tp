<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<HBox spacing="10" alignment="CENTER" styleClass="stack-pane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <TextField fx:id="commandTextField"
             onAction="#handleCommandEntered"
             promptText="Enter command here..."
             HBox.hgrow="ALWAYS" />

  <Button fx:id="executeButton"
          mnemonicParsing="false"
          onAction="#handleCommandEntered"
          text="Execute"
          minWidth="-Infinity"
          styleClass="execute-button"/>
</HBox>
